{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "api/v6/deployments.php", "use": "vercel-php@0.9.0" },
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "**/*.css", "use": "@vercel/static" },
    { "src": "**/*.js", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/v6/deployments(.*)",
      "dest": "/api/v6/deployments.php"
    }
  ]
}
