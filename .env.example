# Vercel Environment Variables
# Add these in Vercel Dashboard > Project > Settings > Environment Variables

NEXT_PUBLIC_SITE_URL=https://chemistry-code.com
SITE_URL=https://chemistry-code.com

# Tap Payments
# Use test key first, then switch to live key after approval/testing.
TAP_SECRET_KEY=sk_test_YOUR_TAP_SECRET_KEY


# PayPal Checkout
# Use sandbox first. For live, set PAYPAL_MODE=live and use live client/secret.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_CURRENCY=USD
# If your plan prices are in EGP and PayPal currency is USD, this converts EGP to USD on the server.
PAYPAL_CONVERT_EGP_TO_USD=true
PAYPAL_EGP_TO_USD_RATE=50
